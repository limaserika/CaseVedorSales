            <ui:InvokeCode ContinueOnError="{x:Null}" sap2010:Annotation.AnnotationText="Aqui eu transformo o texto extraído do PDF em DataTable, para ser mais facil de manipular.&#xA;Já aproveito para criar as colunas necessarias para o excel de relatório." Code="DataTable dt = new DataTable();&#xD;&#xA;&#xD;&#xA;// Colunas existentes no PDF&#xD;&#xA;dt.Columns.Add(&quot;Invoice&quot;, typeof(string));&#xD;&#xA;dt.Columns.Add(&quot;Date&quot;, typeof(string));&#xD;&#xA;dt.Columns.Add(&quot;PostalCode&quot;, typeof(string));&#xD;&#xA;dt.Columns.Add(&quot;VendorID&quot;, typeof(string));&#xD;&#xA;dt.Columns.Add(&quot;ItemType&quot;, typeof(string));&#xD;&#xA;dt.Columns.Add(&quot;Qty&quot;, typeof(string));&#xD;&#xA;dt.Columns.Add(&quot;UnitCost&quot;, typeof(string));&#xD;&#xA;dt.Columns.Add(&quot;TotalPrice&quot;, typeof(string));&#xD;&#xA;&#xD;&#xA;// Colunas que tenho de adicionar&#xD;&#xA;dt.Columns.Add(&quot;ValorUnitario&quot;, typeof(string));&#xD;&#xA;dt.Columns.Add(&quot;ValorTotal&quot;, typeof(string));&#xD;&#xA;dt.Columns.Add(&quot;DataHoraCambio&quot;, typeof(string));&#xD;&#xA;dt.Columns.Add(&quot;Endereco&quot;, typeof(string));&#xD;&#xA;dt.Columns.Add(&quot;Bairro&quot;, typeof(string));&#xD;&#xA;dt.Columns.Add(&quot;LocalidadeUF&quot;, typeof(string));&#xD;&#xA;dt.Columns.Add(&quot;ErrosEncontrados&quot;, typeof(string));&#xD;&#xA;&#xD;&#xA;// Transforma o texto (\n\r) numa quebra de linha real&#xD;&#xA;string realText = inputText;&#xD;&#xA;&#xD;&#xA;realText = realText.Replace(&quot;\\r\\n&quot;, Environment.NewLine);&#xD;&#xA;realText = realText.Replace(&quot;\\n&quot;, Environment.NewLine);&#xD;&#xA;realText = realText.Replace(&quot;\\r&quot;, Environment.NewLine);&#xD;&#xA;&#xD;&#xA;// Quebra em linhas reais&#xD;&#xA;string[] lines = realText.Split(&#xD;&#xA;    new string[] { Environment.NewLine },&#xD;&#xA;    StringSplitOptions.RemoveEmptyEntries&#xD;&#xA;);&#xD;&#xA;&#xD;&#xA;foreach (string rawLine in lines)&#xD;&#xA;{&#xD;&#xA;    string line = rawLine.Trim();&#xD;&#xA;&#xD;&#xA;    if (string.IsNullOrWhiteSpace(line))&#xD;&#xA;        continue;&#xD;&#xA;&#xD;&#xA;    if (line.StartsWith(&quot;INVOICE&quot;))&#xD;&#xA;        continue;&#xD;&#xA;&#xD;&#xA;    // Separa por 2 ou mais espaços, pois um espaço é comum.&#xD;&#xA;    string[] parts = System.Text.RegularExpressions.Regex.Split(line, @&quot;\s{2,}&quot;);&#xD;&#xA;&#xD;&#xA;    if (parts.Length &lt; 8)&#xD;&#xA;        continue;&#xD;&#xA;&#xD;&#xA;    dt.Rows.Add(&#xD;&#xA;        parts[0].Trim(), // Invoice&#xD;&#xA;        parts[1].Trim(), // Date&#xD;&#xA;        parts[2].Trim(), // PostalCode&#xD;&#xA;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;// Aqui esta diferente, pois estou usando Reex para tratar os Ids dos vendedores que veio espaço&#xD;&#xA;&#x9;&#x9;System.Text.RegularExpressions.Regex.Replace(parts[3], @&quot;\s+&quot;, &quot;&quot;).ToUpper().Trim(), // VendorID&#xD;&#xA;        &#xD;&#xA;&#x9;&#x9;parts[4].Trim(), // ItemType&#xD;&#xA;        parts[5].Trim(), // Qty&#xD;&#xA;        parts[6].Trim(), // UnitCost&#xD;&#xA;        parts[7].Trim(), // TotalPrice&#xD;&#xA;&#x9;&#x9;&quot;&quot;, // Valor Unitário (BRL)&#xD;&#xA;&#x9;&#x9;&quot;&quot;, // Valor Total (BRL)&#xD;&#xA;&#x9;&#x9;&quot;&quot;, // Data/Hora Conversão do Câmbio&#xD;&#xA;&#x9;&#x9;&quot;&quot;, // Endereço&#xD;&#xA;&#x9;&#x9;&quot;&quot;, // Bairro&#xD;&#xA;&#x9;&#x9;&quot;&quot;, //Localidade/UF&#xD;&#xA;&#x9;&#x9;&quot;&quot; // Erros Encontrados&#xD;&#xA;    );&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;outputDT = dt;" DisplayName="Invoke Code" sap:VirtualizedContainerService.HintSize="478,274" sap2010:WorkflowViewState.IdRef="InvokeCode_1" Language="CSharp">
